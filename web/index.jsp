<!DOCTYPE html>

<html lang="pt-BR">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>ClínicaWeb</title>

    <link
        rel="stylesheet"
        href="css/estilo.css"
    >

</head>

<body>

<div class="topbar">

    <a href="index.jsp" class="logo">

        <div class="logo-icon">
            <div class="cross-horizontal"></div>
            <div class="cross-vertical"></div>
        </div>

        <div class="logo-text">
            <span class="logo-clinica">Clínica</span><span class="logo-web">Web</span>
        </div>

    </a>

</div>

<div class="sidebar">

    <a href="paciente">
        Pacientes
    </a>

    <a href="medico">
        Médicos
    </a>

    <a href="consulta">
        Consultas
    </a>

</div>

<div class="content">

    <div class="card welcome-card">

        <h1 class="page-title">
            Bem-vindo ao Sistema ClínicaWeb
        </h1>

        <p>
            Utilize o menu lateral para acessar os módulos de pacientes, médicos e consultas.
        </p>

        <div class="quick-info">

            <div class="info-box">
                <span class="info-title">Pacientes</span>
                <span class="info-text">Cadastro e gerenciamento</span>
            </div>

            <div class="info-box">
                <span class="info-title">Médicos</span>
                <span class="info-text">Especialidades e situaçăo</span>
            </div>

            <div class="info-box">
                <span class="info-title">Consultas</span>
                <span class="info-text">Agendamentos e valores</span>
            </div>

        </div>

    </div>

</div>

</body>

</html>